<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#0D1B2A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ALTogelun Prediksi"
        android:textColor="#FFD700"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Prediction Engine"
        android:textColor="#B0C4DE"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnKeluaran"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Keluaran Pasaran (Tabel)"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#1E6091"/>

    <Button
        android:id="@+id/btnPrediksiSdy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 Prediksi Sydney"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#D62828"/>

    <Button
        android:id="@+id/btnPrediksiSgp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 Prediksi Singapura"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#F77F00"/>

    <Button
        android:id="@+id/btnPrediksiHk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎯 Prediksi Hongkong"
        android:backgroundTint="#2A9D8F"/>

</LinearLayout>
